{
  "name": "search_vault",
  "description": "Инструмент для безопасного чтения базы знаний (Vault). Выполняет поиск по YAML-тегам и тексту.",
  "command": "python3 /app/src/eggent_skills/search_vault.py",
  "schema": {
    "type": "object",
    "properties": {
      "text": {
        "type": "string",
        "description": "Строка для полнотекстового поиска."
      },
      "metadata": {
        "type": "object",
        "properties": {
          "tags": { "type": "array", "items": { "type": "string" } },
          "domain": { "type": "string" },
          "project": { "type": "string" }
        }
      }
    }
  }
}
